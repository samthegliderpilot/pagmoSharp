{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pagmo.NET: Run Tests",
      "type": "coreclr",
      "request": "launch",
      "program": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/test.ps1",
        "-Configuration",
        "Debug",
        "-Stage",
        "test",
        "-NoRestore"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Pagmo.NET: build tests (Debug x64)",
      "console": "integratedTerminal"
    },
    {
      "name": "Pagmo.NET: Debug Examples",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/Examples/Examples.Pagmo.NET/bin/x64/Debug/net10.0/Examples.Pagmo.NET.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Examples/Examples.Pagmo.NET",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "preLaunchTask": "Pagmo.NET: build examples (Debug x64)"
    }
  ]
}
