{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pagmo.NET: Debug Tests",
      "type": "coreclr",
      "request": "launch",
      "program": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/test.ps1",
        "-Configuration",
        "Debug",
        "-Stage",
        "test",
        "-NoRestore"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Pagmo.NET: build tests (Debug x64)",
      "console": "integratedTerminal"
    }
  ]
}
